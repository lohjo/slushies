FLASK_ENV=development
SECRET_KEY=replace-with-a-random-secret

# Development DB (optional; defaults to instance/platform_dev.db when unset)
# DEV_DATABASE_URL=sqlite:///instance/platform_dev.db

# Production DB (required only when FLASK_ENV=production)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Google Sheets source
GOOGLE_SHEET_ID=replace-with-your-google-sheet-id
GOOGLE_SHEET_RANGE=Sheet1!A2:AJ

# Choose one auth method:
# 1) File path (local dev)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account-key.json
# 2) Raw JSON blob (hosted environments)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Webhook shared secret (must match Apps Script)
WEBHOOK_SECRET=replace-with-a-strong-shared-secret
WEBHOOK_RATE_LIMIT=30 per minute

# Optional behavior and mail settings
SHEETS_ALLOW_EMPTY=false
MAIL_USERNAME=
MAIL_PASSWORD=
